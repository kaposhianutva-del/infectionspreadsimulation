<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Virus Spread Simulation</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      background: #f4f6f8;
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 20px;
    }

    .slider-box {
      background: white;
      padding: 10px;
      border-radius: 8px;
      width: 220px;
    }

    canvas {
      background: white;
      border-radius: 8px;
      padding: 10px;
    }

    table {
      border-collapse: collapse;
      margin-top: 20px;
      width: 100%;
      background: white;
    }

    th, td {
      border: 1px solid #ddd;
      padding: 6px;
      text-align: center;
    }

    th {
      background: #eee;
    }

    button {
      padding: 10px 15px;
      margin: 10px 0;
      cursor: pointer;
    }
  </style>
</head>

<body>

<h2>Virus Spread Simulation (SIR Model)</h2>

<div class="controls">
  <div class="slider-box">
    Infection Rate<br>
    <input type="range" id="infectionRate" min="0.0" max="1" step="0.01" value="0.3">
    <div id="irVal"></div>
  </div>

  <div class="slider-box">
    Contact Rate<br>
    <input type="range" id="contactRate" min="0" max="20" step="1" value="8">
    <div id="crVal"></div>
  </div>

  <div class="slider-box">
    Recovery Rate<br>
    <input type="range" id="recoveryRate" min="0.01" max="0.5" step="0.01" value="0.1">
    <div id="rrVal"></div>
  </div>

  <div class="slider-box">
    Immunity Level<br>
    <input type="range" id="immunity" min="0" max="1" step="0.01" value="0.1">
    <div id="imVal"></div>
  </div>
</div>

<button onclick="runSimulation()">Run Simulation</button>

<canvas id="chart" height="120"></canvas>

<div id="summary"></div>

<table id="dataTable"></table>

<script>
let chart;

function runSimulation() {
  const infectionRate = parseFloat(document.getElementById("infectionRate").value);
  const contactRate = parseFloat(document.getElementById("contactRate").value);
  const recoveryRate = parseFloat(document.getElementById("recoveryRate").value);
  const immunity = parseFloat(document.getElementById("immunity").value);

  const population = 500;
  let S = population * (1 - immunity) - 1;
  let I = 1;
  let R = population * immunity;

  let days = 60;

  let S_data = [];
  let I_data = [];
  let R_data = [];
  let labels = [];

  let peakInfected = 0;
  let peakDay = 0;

  for (let t = 0; t < days; t++) {
    labels.push(t);

    let newInfections = infectionRate * contactRate * (S / population) * I;
    let newRecoveries = recoveryRate * I;

    newInfections = Math.min(S, newInfections);

    S -= newInfections;
    I += newInfections - newRecoveries;
    R += newRecoveries;

    S_data.push(S.toFixed(0));
    I_data.push(I.toFixed(0));
    R_data.push(R.toFixed(0));

    if (I > peakInfected) {
      peakInfected = I;
      peakDay = t;
    }
  }

  document.getElementById("summary").innerHTML = `
    <h3>Results</h3>
    Peak Infection: ${peakInfected.toFixed(0)} on Day ${peakDay}
  `;

  const ctx = document.getElementById('chart').getContext('2d');

  if (chart) chart.destroy();

  chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'Susceptible',
          data: S_data,
          borderColor: 'blue',
          fill: false
        },
        {
          label: 'Infected',
          data: I_data,
          borderColor: 'red',
          fill: false
        },
        {
          label: 'Recovered',
          data: R_data,
          borderColor: 'green',
          fill: false
        }
      ]
    }
  });

  buildTable(labels, S_data, I_data, R_data);
}

function buildTable(labels, S, I, R) {
  let html = `
    <tr>
      <th>Day</th>
      <th>Susceptible</th>
      <th>Infected</th>
      <th>Recovered</th>
    </tr>
  `;

  for (let i = 0; i < labels.length; i += 5) {
    html += `
      <tr>
        <td>${labels[i]}</td>
        <td>${S[i]}</td>
        <td>${I[i]}</td>
        <td>${R[i]}</td>
      </tr>
    `;
  }

  document.getElementById("dataTable").innerHTML = html;
}

// live slider display
function bindSliders() {
  const ids = ["infectionRate", "contactRate", "recoveryRate", "immunity"];

  ids.forEach(id => {
    const el = document.getElementById(id);
    const out = document.getElementById(id.slice(0,2) + "Val");

    const update = () => out.innerText = el.value;

    el.addEventListener("input", update);
    update();
  });
}

bindSliders();
</script>

</body>
</html>
